# ============================================================
# DIME Video Generation System — Environment Configuration
# ============================================================

# --- Inference Backend ---
# Options: "local" (RTX 4080), "dgx" (DGX A100 cluster)
INFERENCE_BACKEND=local

# --- vLLM Endpoints ---
# Local (RTX 4080)
LOCAL_BRAIN_URL=http://localhost:8001/v1
LOCAL_CODER_URL=http://localhost:8002/v1

# DGX A100 (update IP to your actual DGX address)
DGX_BRAIN_URL=http://172.16.10.220:8001/v1
DGX_CODER_URL=http://172.16.10.220:8002/v1

# --- Model Names (used in vLLM --served-model-name) ---
BRAIN_MODEL_NAME=Qwen/Qwen2.5-VL-7B-Instruct
CODER_MODEL_NAME=Qwen/Qwen2.5-Coder-7B-Instruct

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Database ---
DATABASE_URL=sqlite:///./data/vidgen.db

# --- Wolfram Alpha ---
WOLFRAM_APP_ID=your-wolfram-app-id-here

# --- TTS ---
TTS_MODEL=kokoro
TTS_VOICE=af_heart
TTS_SAMPLE_RATE=24000

# --- Manim ---
MANIM_QUALITY=h
MANIM_RESOLUTION=1920x1080
MANIM_TIMEOUT_SECONDS=90
MAX_RENDER_WORKERS=6
MAX_RENDER_WORKERS_FALLBACK=3

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_DOCS=manim_docs
CHROMA_COLLECTION_EXAMPLES=validated_examples

# --- Storage ---
OUTPUT_DIR=./output
VIDEO_CACHE_TTL_SECONDS=15552000

# --- Docker Sandbox ---
DOCKER_IMAGE_NAME=dime-manim-sandbox
DOCKER_MEMORY_LIMIT=4g
DOCKER_CPU_LIMIT=2

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Coder Retry ---
MAX_CODER_RETRIES=4
